# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Voyage AI — optional, powers photo similarity search
# Sign up at https://voyageai.com and create an API key
VOYAGE_API_KEY=

# Sentry — Error monitoring (optional for local dev)
# Create a project at https://sentry.io and grab the DSN
NEXT_PUBLIC_SENTRY_DSN=

# Sentry CI-only secrets (set in GitHub Actions, not locally)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
